<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:ignore="MissingPrefix">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/background"
        android:background="@color/spin_back">

        <ImageView
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_gravity="right"
            android:layout_marginRight="-70dp"
            android:layout_marginTop="-50dp"
            android:id="@+id/programImage"/>

        <ImageView
            android:layout_width="260dp"
            android:layout_height="280dp"
            android:layout_gravity="right"
            android:layout_marginTop="-60dp"
            android:id="@+id/animatingImage"
            android:layout_marginRight="-60dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginTop="30dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:id="@+id/programName"
                fontPath="fonts/Poppins-Bold.otf"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:id="@+id/level"
                android:textSize="12sp"
                android:visibility="gone"
                fontPath="fonts/Poppins-Light.otf"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                fontPath="fonts/Poppins-Light.otf"
                android:id="@+id/points"
                android:layout_marginTop="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:id="@+id/expiryDate"
                android:text="Expires at 01 Jan 2027 00:00"
                fontPath="fonts/Poppins-Light.otf"
                android:layout_marginBottom="80dp"
                android:layout_marginTop="5dp"/>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:id="@+id/playNow"
            android:layout_gravity="bottom">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:id="@+id/view"
                android:alpha="0.3"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Play Now"
                android:id="@+id/playNowText"
                android:textColor="@color/white"
                android:layout_gravity="center"/>

        </FrameLayout>

    </FrameLayout>

</FrameLayout>